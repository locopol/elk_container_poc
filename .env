# =============================================================================
# Piloto Elasticsearch - Variables de entorno (EJEMPLO)
# Copiar como .env y modificar las credenciales segun necesidad
# =============================================================================

# Credenciales del usuario elastic (administrador principal)
# Debe tener al menos 6 caracteres, solo alfanumericos
ELASTIC_PASSWORD=<redacted>

# Credenciales del usuario kibana_system
# Debe tener al menos 6 caracteres, solo alfanumericos
KIBANA_PASSWORD=<redacted>

# Version de los productos Elastic
STACK_VERSION=8.19.16

# Nombre del cluster (identificar en Kibana y logs)
CLUSTER_NAME=piloto-elastic-cluster

# Tipo de licencia: basic (default) o trial (30 dias premium)
LICENSE=basic
# LICENSE=trial

# =============================================================================
# PUERTOS Y RED - Elasticsearch (es01: nodo principal)
# =============================================================================
# ES_HOST: interfaz donde es01 expone la API HTTP.
#   0.0.0.0 = accesible desde cualquier interfaz de red
#   127.0.0.1 = solo accesible localmente (más seguro)
ES_HOST=0.0.0.0
ES_PORT=9200

# Puertos adicionales para es02 y es03 (solo es01 expuesto por defecto)
# Formato: HOST_IP:HOST_PORT:CONTAINER_PORT
ES_HOST_2=${ES_HOST}
ES_PORT_2=9201
ES_HOST_3=${ES_HOST}
ES_PORT_3=9202

# =============================================================================
# PUERTOS - Kibana
# =============================================================================
# KIBANA_HOST: interfaz donde Kibana expone la UI web.
#   Por defecto 127.0.0.1 (más seguro, solo accesible localmente).
KIBANA_HOST=127.0.0.1
KIBANA_PORT=5601

# =============================================================================
# VOLUMENES (bind mounts en lugar de volumes nombrados)
# =============================================================================

# Directorio base para todos los datos persistentes (formato Docker/WSL2)
# En Windows usa el path absoluto con forward slashes o el path de WSL2
# Ejemplo Windows: DATA_DIR_BASE=D:/sysinternals/nanocoder/PILOTO-ELK/config
# Ejemplo Linux:   DATA_DIR_BASE=/home/usuario/pioto-elk/config
DATA_DIR_BASE=<CUSTOM_DATA_DIR>

# Deshabilitar bind mounts y usar volumes Docker (default: false)
# Cuando USE_BIND_MOUNTS=false, se usan volumes nombrados (comportamiento anterior)
USE_BIND_MOUNTS=true

# Ruta para datos de Elasticsearch por nodo (relativa a DATA_DIR_BASE)
ES01_DATA_DIR=esdata01
ES02_DATA_DIR=esdata02
ES03_DATA_DIR=esdata03

# Ruta para certificados TLS (relativa a DATA_DIR_BASE)
CERTS_DIR=certs

# Ruta para datos de Kibana (relativa a DATA_DIR_BASE)
KIBANA_DATA_DIR=kibanadata

# =============================================================================
# RECURSOS
# =============================================================================

# Limite de memoria por contenedor (en bytes)
# 2 GB = 2147483648 bytes. Necesario para cluster de 3 nodos con TLS y monitoreo.
MEM_LIMIT=2147483648

# Nombre del proyecto Docker Compose (por defecto usa nombre de carpeta)
# COMPOSE_PROJECT_NAME=piloto-elk
